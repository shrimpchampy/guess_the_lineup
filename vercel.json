{
  "rewrites": [{"source": "/day/:path*", "destination": "/day/index.html"}],
  "headers": [
    {
      "source": "/",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"},
        {"key": "Pragma", "value": "no-cache"}
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"},
        {"key": "Pragma", "value": "no-cache"}
      ]
    },
    {
      "source": "/day/index.html",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"},
        {"key": "Pragma", "value": "no-cache"}
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}
      ]
    }
  ]
}
